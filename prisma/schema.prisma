generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                   String    @id @default(cuid())
  email                String    @unique
  password_hash        String?
  username             String?   @unique
  handle               String?   @unique
  display_name         String?
  full_name            String?
  role                 String    @default("user")
  admin_role           String?
  is_admin             Boolean   @default(false)
  email_verified       Boolean   @default(false)
  credits              Float     @default(0)
  wallet_balance       Float     @default(0)
  lifetime_earnings    Float     @default(0)
  trophies             Int       @default(0)
  rank                 String?   @default("novice")
  division             String?   @default("I")
  xp_level             Int       @default(1)
  wager_wins           Int       @default(0)
  wager_losses         Int       @default(0)
  current_win_streak   Int       @default(0)
  total_wager_earnings Float     @default(0)
  biggest_wager_win    Float     @default(0)
  tournament_wins      Int       @default(0)
  region               String?
  is_premium           Boolean   @default(false)
  premium_expires      DateTime?
  is_banned            Boolean   @default(false)
  ban_reason           String?
  account_created_date DateTime  @default(now())
  created_date         DateTime  @default(now())
  updated_date         DateTime  @updatedAt
  metadata             Json      @default("{}")
}

model Role {
  id           String   @id @default(cuid())
  key          String   @unique
  label        String
  color        String
  power        Int
  created_date DateTime @default(now())
  updated_date DateTime @updatedAt
}

model RankTier {
  id           String   @id @default(cuid())
  key          String   @unique
  name         String
  tier         String
  division     String?
  min_elo      Int
  max_elo      Int?
  color        String
  created_date DateTime @default(now())
  updated_date DateTime @updatedAt
}

